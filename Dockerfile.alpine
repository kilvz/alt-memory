FROM alpine:3.21

RUN apk add --no-cache python3 py3-pip py3-numpy py3-scipy git

WORKDIR /test
COPY . /test/alt-memory

RUN sed -i 's/setuptools.backends._legacy:_Backend/setuptools.build_meta/' /test/alt-memory/pyproject.toml

# Install with deps (faiss now has musl wheels)
RUN pip install --break-system-packages /test/alt-memory 2>&1

# Test --help
RUN python3 -m alt_memory.cli --help 2>&1

CMD ["python3", "-m", "alt_memory.cli", "--help"]
